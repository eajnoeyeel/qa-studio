# Application
APP_NAME=SaaS CS QA Studio
DEBUG=true
API_PREFIX=/api/v1

# Database (SQLite for dev, Postgres for prod)
DATABASE_URL=sqlite:///./cs_qa_studio.db
# DATABASE_URL=postgresql://user:password@localhost:5432/cs_qa_studio

# Langfuse (optional - graceful fallback if not set)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# LLM Provider
# Options: mock, openai, anthropic
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# RAG Settings
DOCS_PATH=./docs
VECTOR_STORE_PATH=./vector_store
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5

# Sampling Thresholds
AB_AMBIGUOUS_THRESHOLD=2.0
LOW_SCORE_THRESHOLD=2
